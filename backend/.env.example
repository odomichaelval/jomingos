# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# CORS (Next.js)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SQL Server (Azure SQL) - set these to enable SQL Server backend
# Use DJANGO_DB_ENGINE=mssql to switch from SQLite to SQL Server.
DJANGO_DB_ENGINE=mssql
DJANGO_DB_HOST=your-server-name.database.windows.net
DJANGO_DB_PORT=1433
DJANGO_DB_NAME=Jomingos
DJANGO_DB_USER=your-sql-username
DJANGO_DB_PASSWORD=your-sql-password

# ODBC driver settings (Windows dev box)
DJANGO_DB_DRIVER=ODBC Driver 18 for SQL Server
DJANGO_DB_TRUST_CERT=yes

# If you deploy to Azure and enable HTTPS domains, add them here:
# CSRF_TRUSTED_ORIGINS=https://your-backend.azurewebsites.net

